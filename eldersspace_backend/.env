# Copy .env.example to .env and fill in your own values
# Database Configuration
DB_HOST=35.224.199.144
DB_PORT=3306
DB_USER=elderdblite
DB_PASSWORD=!Gusnxxb0
DB_DATABASE=eldersspace
DB_CONNECTION_LIMIT=5

# Cloud SQL Configuration (Optional)
# Set to 'true' if using Cloud SQL Proxy, or provide connection name for direct connection
USE_CLOUD_SQL_PROXY=false
# Example: CLOUD_SQL_CONNECTION_NAME=project-id:region:instance-name
CLOUD_SQL_CONNECTION_NAME=
# Path to Cloud SQL SSL certificate (for direct connections)
# DB_SSL_CA=/path/to/server-ca.pem

# Twilio SMS Configuration
# Leave these empty for development mode (OTP will be logged to console)
# Get these from https://www.twilio.com/console to enable SMS sending
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Admin Token Secret (Change this in production!)
ADMIN_AUTH_SECRET=eldersspace-admin-secret-change-me


FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Backend public URL - used for building image URLs returned to clients
# Android emulator: http://10.0.2.2:3000
# Physical device on LAN: http://[YOUR_MACHINE_IP]:3000
# e.g. http://192.168.1.100:3000
BACKEND_URL=http://10.0.2.2:3000

# Environment
NODE_ENV=development
PORT=3000

