# Database Configuration - Supabase (PostgreSQL)
# Get these values from your Supabase project's connection settings
DB_HOST=your-project.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=postgres
DB_CONNECTION_LIMIT=5
# Only needed if your Postgres connection requires a custom CA certificate
DB_SSL_CA=

# Supabase project API (used for storage / service-role operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Admin auth
# Required — server refuses to start without it. Used to sign/verify admin HMAC tokens.
ADMIN_AUTH_SECRET=change_me_to_a_long_random_secret
# Required by the adminAuth middleware (x-admin-key header) on legacy admin routes.
ADMIN_SECRET_KEY=change_me_to_a_long_random_secret
# Fallback admin login PIN, only used if the users table has no password column.
ADMIN_LOGIN_PIN=change_me

# Public URL this backend is reachable at (used to build absolute links, e.g. shared posts)
BACKEND_URL=https://eldersspace-backend.onrender.com

# Firebase Admin SDK service account JSON (as a single-line JSON string), used for FCM push
FIREBASE_SERVICE_ACCOUNT_JSON=

# Google Cloud Text-to-Speech API key (server-side only — proxied via /api/tts)
GOOGLE_TTS_API_KEY=

# Environment
NODE_ENV=development
PORT=3000
